{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node"],
    "paths": {
      "@pages/*": ["./pages/*"],
      "@fixtures/*": ["./tests/fixtures/*"]
    }
  },
  "include": ["tests/**/*.ts", "pages/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
